{
  "name": "repro-in-a-box",
  "version": "2.7.0",
  "description": "Production-grade automated bug detection with 10 detectors and 215+ tests. Find bugs with Playwright, configure detectors, record HAR files, validate reproducibility, and integrate with Claude Desktop via MCP.",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "repro": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "mcp": "node dist/mcp/index.js",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write"
  },
  "keywords": [
    "qa",
    "testing",
    "playwright",
    "bug-detection",
    "mcp",
    "har",
    "reproducibility",
    "accessibility",
    "web-vitals",
    "automation"
  ],
  "author": "forbiddenlink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forbiddenlink/repro-in-a-box.git"
  },
  "bugs": {
    "url": "https://github.com/forbiddenlink/repro-in-a-box/issues"
  },
  "homepage": "https://github.com/forbiddenlink/repro-in-a-box#readme",
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.50.0",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "axe-playwright": "^2.2.2",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "inquirer": "^9.3.8",
    "playwright": "^1.50.0",
    "tsx": "^4.21.0",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "minimatch": ">=9.0.7",
      "next": ">=16.2.3",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4",
      "postcss": ">=8.5.3",
      "rollup": ">=4.59.0",
      "vite": ">=6.4.2",
      "ws": ">=8.18.2"
    }
  }
}

{
  "name": "repro-in-a-box",
  "version": "2.5.0",
  "description": "Production-grade automated bug detection, reproduction, and validation tool with 112+ tests. Find bugs with Playwright, record HAR files, validate reproducibility, and integrate with Claude Desktop.",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "repro": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "mcp": "node dist/mcp/index.js"
  },
  "keywords": [
    "qa",
    "testing",
    "playwright",
    "bug-detection",
    "mcp",
    "har",
    "reproducibility",
    "accessibility",
    "web-vitals",
    "automation"
  ],
  "author": "forbiddenlink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/forbiddenlink/repro-in-a-box.git"
  },
  "bugs": {
    "url": "https://github.com/forbiddenlink/repro-in-a-box/issues"
  },
  "homepage": "https://github.com/forbiddenlink/repro-in-a-box#readme",
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "axe-playwright": "^2.2.2",
    "commander": "^12.1.0",
    "inquirer": "^9.3.8",
    "playwright": "^1.50.0",
    "tsx": "^4.21.0",
    "web-vitals": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.19.33",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
